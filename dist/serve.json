{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/healthz", "destination": "/healthz.txt" },

    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/how-it-works", "destination": "/how-it-works/index.html" },
    { "source": "/calculator", "destination": "/calculator/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/:slug([a-z0-9_-]+)", "destination": "/blog/:slug/index.html" },
    { "source": "/catalog", "destination": "/catalog/index.html" },
    { "source": "/catalog/:id([a-z0-9_-]+)", "destination": "/catalog/:id/index.html" },
    { "source": "/legal", "destination": "/legal/index.html" },
    { "source": "/legal/:docType([a-z]+)", "destination": "/legal/:docType/index.html" },

    { "source": "/login", "destination": "/spa.html" },
    { "source": "/register", "destination": "/spa.html" },
    { "source": "/pay/:paymentId", "destination": "/spa.html" },
    { "source": "/dashboard", "destination": "/spa.html" },
    { "source": "/dashboard/**", "destination": "/spa.html" },
    { "source": "/admin", "destination": "/spa.html" },
    { "source": "/admin/**", "destination": "/spa.html" }
  ],
  "headers": [
    {
      "source": "**",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/**",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/**",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/{og,icons}/**",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/{favicon.ico,favicon.svg,apple-touch-icon.png}",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/{sitemap.xml,robots.txt}",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/healthz",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
